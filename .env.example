# Copy this file to .env and fill in your values. .env is gitignored —
# never commit real Jira credentials.

# Port the Express server (server.js) listens on.
PORT=8000

# Jira Cloud instance base URL, e.g. https://yourcompany.atlassian.net
JIRA_BASE_URL=

# Jira account email used to generate the API token below.
JIRA_EMAIL=

# Jira API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Custom field ID that holds Acceptance Criteria on your tickets, e.g.
# customfield_10105. Find it via:
#   GET {JIRA_BASE_URL}/rest/api/3/field  (search the response for its name)
# Leave blank to skip fetching Acceptance Criteria.
JIRA_AC_FIELD_ID=
